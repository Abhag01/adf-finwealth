{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-finwealth01"
		},
		"ls_blob_finwealth01_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_blob_finwealth01'"
		},
		"kvfinwealth01_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-finwealth01.vault.azure.net/"
		},
		"ls_sql_finwealth01_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-finwealth01-server.database.windows.net"
		},
		"ls_sql_finwealth01_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sql-db-finwealth01"
		},
		"ls_sql_finwealth01_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "gosain"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-finwealth01_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_blob_finwealth01_connectionString": {
						"value": "[parameters('ls_blob_finwealth01_connectionString')]"
					},
					"kvfinwealth01_properties_typeProperties_baseUrl": {
						"value": "[parameters('kvfinwealth01_properties_typeProperties_baseUrl')]"
					},
					"ls_sql_finwealth01_properties_typeProperties_server": {
						"value": "[parameters('ls_sql_finwealth01_properties_typeProperties_server')]"
					},
					"ls_sql_finwealth01_properties_typeProperties_database": {
						"value": "[parameters('ls_sql_finwealth01_properties_typeProperties_database')]"
					},
					"ls_sql_finwealth01_properties_typeProperties_userName": {
						"value": "[parameters('ls_sql_finwealth01_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-finwealth01_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-finwealth01_ArmTemplate_0')]"
			]
		}
	]
}